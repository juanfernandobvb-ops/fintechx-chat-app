# Exemplo de configuração de variáveis de ambiente
# Copie este arquivo para .env e preencha com suas informações

# Google AI Studio (Gemini) API Key
# Obtenha gratuitamente em: https://makersuite.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Modelo Gemini (opcional, padrão: gemini-pro)
VITE_GEMINI_MODEL=gemini-pro

# Configurações do assistente (opcional)
VITE_ASSISTANT_NAME=FinTechX Assistant
VITE_COMPANY_NAME=FinTechX